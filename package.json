{
  "name": "playable-lessons",
  "version": "0.1.0",
  "description": "Interactive Fiction Authoring Tool for Education — Generate playable branching stories from source material using AI + Ink",
  "main": "./out/main/index.mjs",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps || true",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:cli": "tsc -p tsconfig.cli.json",
    "prepublishOnly": "npm run build:cli",
    "cli": "npx tsx src/cli/index.ts"
  },
  "bin": {
    "playable-lessons": "./out/cli/index.js"
  },
  "files": [
    "out/cli/",
    "out/shared/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "interactive-fiction",
    "education",
    "ink",
    "electron",
    "storytelling",
    "narrative",
    "authoring",
    "cli"
  ],
  "author": "michael-borck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael-borck/playable-lessons.git"
  },
  "homepage": "https://github.com/michael-borck/playable-lessons",
  "dependencies": {
    "@xyflow/react": "^12.10.2",
    "inkjs": "^2.4.0",
    "jszip": "^3.10.1",
    "marked": "^17.0.5",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "yargs": "^18.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.8"
  }
}
