{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "outDir": "./out",
    "rootDir": "./src",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src/cli/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["**/*.test.ts"]
}
