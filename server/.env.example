# Playable Lessons — self-hosted server config
# Copy to .env and fill in. The server reads this on startup.

# ─── AI provider (set ONE) ───
# Anthropic Claude:
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI:
# OPENAI_API_KEY=sk-...

# Ollama (local/remote):
# OLLAMA_URL=http://localhost:11434
# OLLAMA_TOKEN=

# Model (defaults: claude-sonnet-4-20250514 / gpt-4o / llama3.1:8b)
# MODEL=claude-sonnet-4-20250514
# Comma-separated for multiple groups (e.g. staff-2024,pilot-group,admin).
# Revoke access by removing a code and restarting.
ACCESS_CODE=

# ─── Limits ───
RATE_LIMIT_PER_HOUR=30
MAX_INPUT_CHARS=20000
PORT=3000
