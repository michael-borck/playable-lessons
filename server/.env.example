# Playable Lessons — self-hosted server config
# Place this file as .env in the same directory as docker-compose.yml.

# ─── AI provider (set ONE) ───
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI:
# OPENAI_API_KEY=sk-...

# Ollama (local/remote):
# OLLAMA_URL=http://localhost:11434
# OLLAMA_TOKEN=

# ─── Model ───
# Specify the model to use. Defaults if omitted:
#   Claude:  claude-sonnet-4-20250514
#   OpenAI:  gpt-4o
#   Ollama:  llama3.1:8b
MODEL=claude-sonnet-4-20250514

# ─── Access gate ───
# Comma-separated for multiple groups (e.g. staff-2024,pilot-group,admin).
# Revoke access by removing a code and restarting.
# Leave blank for no gate (open access).
ACCESS_CODE=

# ─── Limits ───
RATE_LIMIT_PER_HOUR=30
MAX_INPUT_CHARS=20000
PORT=3000
